{
  "name": "msword-writing-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "A Microsoft Word add-in for grammar and spelling review.",
  "scripts": {
    "dev": "next dev --port 3000 --experimental-https --experimental-https-key $HOME/.office-addin-dev-certs/localhost.key --experimental-https-cert $HOME/.office-addin-dev-certs/localhost.crt",
    "build": "next build",
    "start": "npm run dev",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "certs": "npx --yes office-addin-dev-certs install",
    "trust:certs": "certutil -user -addstore Root %USERPROFILE%\\.office-addin-dev-certs\\ca.crt",
    "validate:manifest": "npx --yes office-addin-manifest validate manifest.xml",
    "update": "git pull && npm install"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "@types/office-js": "1.0.591",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3"
  }
}